# ──────────────────────────────────────────────
# Inventory Master - Environment Variables
# Copy this file to .env and adjust values
# ──────────────────────────────────────────────

# ─── Frontend ───
FRONTEND_PORT=80

# ─── API ───
API_PORT=4005
NODE_ENV=production
JWT_SECRET=cambiar-por-un-secreto-seguro

# ─── PostgreSQL ───
DB_EXTERNAL_PORT=5432
DB_HOST=postgres
DB_PORT=5432
DB_NAME=herramientas_app
DB_USER=postgres
DB_PASSWORD=example
DB_SYNC_ALTER=false
